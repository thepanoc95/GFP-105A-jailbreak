diff --git a/include/arch/arm/io.h b/include/arch/arm/io.h
new file mode 100644
index 0000000..db7aa77
--- /dev/null
+++ b/include/arch/arm/io.h
@@ -0,0 +1,29 @@
+/* include/arch/arm/io.h
+ * OpenPhone — ARM memory-mapped I/O
+ *
+ * Copyright (C) 2026 OpenPhone Project
+ * SPDX-License-Identifier: GPL-2.0-only
+ */
+
+#ifndef ARCH_ARM_IO_H
+#define ARCH_ARM_IO_H
+
+#include "types.h"
+
+static inline u8  read8 (u32 addr) { return *(volatile u8  *)addr; }
+static inline u16 read16(u32 addr) { return *(volatile u16 *)addr; }
+static inline u32 read32(u32 addr) { return *(volatile u32 *)addr; }
+
+static inline void write8 (u32 addr, u8  val) { *(volatile u8  *)addr = val; }
+static inline void write16(u32 addr, u16 val) { *(volatile u16 *)addr = val; }
+static inline void write32(u32 addr, u32 val) { *(volatile u32 *)addr = val; }
+
+/* OpenBIOS uses these macros in drivers */
+#define inb(p)      read8(p)
+#define inw(p)      read16(p)
+#define inl(p)      read32(p)
+#define outb(v,p)   write8(p,v)
+#define outw(v,p)   write16(p,v)
+#define outl(v,p)   write32(p,v)
+
+#endif /* ARCH_ARM_IO_H */
