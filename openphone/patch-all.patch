diff --git a/arch/arm/mt6261/lcd.c b/arch/arm/mt6261/lcd.c
new file mode 100644
index 0000000..13df2b3
--- /dev/null
+++ b/arch/arm/mt6261/lcd.c
@@ -0,0 +1,313 @@
+/* arch/arm/mt6261/lcd.c
+ * OpenPhone — MT6261 LCD controller driver
+ * Target: Gradiente Neo Flip 105A (GFP-105A)
+ * Panel: 240x320 QVGA, RGB565 (16bpp)
+ *
+ * Copyright (C) 2026 OpenPhone Project
+ * SPDX-License-Identifier: GPL-2.0-only
+ *
+ * The MT6261 has a built-in parallel LCD interface controller.
+ * The panel is most likely an ILI9341, ILI9163, or ST7789 driven
+ * over an 8/16-bit parallel bus.
+ *
+ * NOTE: The hardware init sequence (mt6261_lcd_hw_init) is stubbed.
+ * Extract the real sequence from dump_preloader.bin:
+ *
+ *   python3 -c "
+ *   import struct
+ *   data = open('dump.bin','rb').read()
+ *   target = bytes([0x00, 0x00, 0x0B, 0x80])  # 0x800B0000 LE
+ *   i = 0
+ *   while True:
+ *       idx = data.find(target, i)
+ *       if idx < 0: break
+ *       print(f'0x800B0000 ref at {idx:#08x}')
+ *       i = idx + 1
+ *   "
+ *
+ * Then disassemble the surrounding Thumb code and transcribe the
+ * register writes into mt6261_lcd_hw_init() below.
+ */
+
+#include "config.h"
+#include "mt6261.h"
+#include "lcd.h"
+
+#define REG32(a)    (*(volatile unsigned int *)(a))
+#define REG16(a)    (*(volatile unsigned short *)(a))
+#define REG8(a)     (*(volatile unsigned char *)(a))
+
+/* ── MT6261 LCD controller registers (offset from MT6261_LCD_BASE) ──────── */
+
+#define LCD_WROI_CTRL       0x0000  /* Write ROI control                    */
+#define LCD_WROI_CMD        0x0004  /* Command/data write                   */
+#define LCD_WROI_DATA       0x0008  /* Data write                           */
+#define LCD_WROI_SIZE       0x000C  /* ROI size (width | height<<16)        */
+#define LCD_WROI_BGCLR      0x0010  /* Background color                     */
+#define LCD_LAYER_EN        0x0020  /* Layer enable                         */
+#define LCD_LAYER0_CTRL     0x0024  /* Layer 0 control                      */
+#define LCD_LAYER0_SRC      0x0028  /* Layer 0 source address               */
+#define LCD_LAYER0_PITCHSZ  0x002C  /* Layer 0 pitch and size               */
+#define LCD_LAYER0_WINDOW   0x0030  /* Layer 0 window position              */
+#define LCD_TEARING_EN      0x0040  /* Tearing effect enable                */
+#define LCD_STATUS          0x0100  /* Controller status                    */
+#define LCD_INTEN           0x0104  /* Interrupt enable                     */
+#define LCD_INTSTA          0x0108  /* Interrupt status                     */
+#define LCD_SERIAL_CFG      0x0200  /* Serial interface config (if SPI)     */
+#define LCD_PARALLEL_CFG    0x0204  /* Parallel interface config            */
+#define LCD_RESET_CTRL      0x0300  /* Reset control                        */
+
+/* LCD_WROI_CTRL bits */
+#define LCD_CTRL_START      (1 << 0)    /* Start transfer                   */
+#define LCD_CTRL_STOP       (1 << 1)    /* Stop transfer                    */
+#define LCD_CTRL_IF_SEL     (1 << 4)    /* Interface select (0=par, 1=ser)  */
+
+/* LCD_PARALLEL_CFG bits */
+#define LCD_PAR_16BIT       (1 << 0)    /* 16-bit parallel bus              */
+#define LCD_PAR_9BIT        (0 << 0)    /* 9-bit parallel bus               */
+
+/* LCD_STATUS bits */
+#define LCD_STATUS_BUSY     (1 << 0)
+
+/* Layer control bits */
+#define LCD_LAYER_RGB565    (0x0 << 4)  /* Pixel format: RGB565             */
+#define LCD_LAYER_RGB888    (0x1 << 4)  /* Pixel format: RGB888             */
+#define LCD_LAYER_EN_BIT    (1 << 0)
+
+/* GPIO for LCD reset and backlight — TODO: verify from dump */
+#define LCD_RESET_GPIO      47          /* GPIO pin for LCD reset           */
+#define LCD_BL_GPIO         11          /* GPIO pin for backlight PWM/on    */
+
+/* ── Framebuffer ────────────────────────────────────────────────────────── */
+
+/* 240*320*2 = 153600 bytes = 150KB
+ * Placed at top of SRAM below the stack.
+ * Stack is at 0x7003FFFC growing down.
+ * Framebuffer: 0x70040000 - 150KB = 0x70016800 .. 0x70040000
+ * But we also need code space — place FB at a fixed known address.
+ */
+#define LCD_FB_BASE         0x70016800  /* 150KB framebuffer in SRAM        */
+#define LCD_FB_WIDTH        240
+#define LCD_FB_HEIGHT       320
+#define LCD_FB_BPP          16          /* RGB565                           */
+#define LCD_FB_STRIDE       (LCD_FB_WIDTH * 2)
+#define LCD_FB_SIZE         (LCD_FB_STRIDE * LCD_FB_HEIGHT)  /* 153600 B   */
+
+static unsigned short *fb = (unsigned short *)LCD_FB_BASE;
+
+/* ── GPIO helpers ───────────────────────────────────────────────────────── */
+
+static void gpio_out(int pin, int val)
+{
+    unsigned int base = MT6261_GPIO_BASE;
+    unsigned int reg  = base + (pin / 16) * 0x10;
+    unsigned int bit  = 1 << (pin % 16);
+    if (val)
+        REG16(reg) |= bit;
+    else
+        REG16(reg) &= ~bit;
+}
+
+static void msleep(int ms)
+{
+    volatile int i = ms * 10000;
+    while (i--)
+        ;
+}
+
+/* ── Panel command/data write (parallel interface) ──────────────────────── */
+
+static void lcd_wait_ready(void)
+{
+    int timeout = 100000;
+    while ((REG32(MT6261_LCD_BASE + LCD_STATUS) & LCD_STATUS_BUSY) && timeout--)
+        ;
+}
+
+static void lcd_write_cmd(unsigned short cmd)
+{
+    lcd_wait_ready();
+    REG32(MT6261_LCD_BASE + LCD_WROI_CMD) = cmd;
+}
+
+static void lcd_write_dat(unsigned short dat)
+{
+    lcd_wait_ready();
+    REG32(MT6261_LCD_BASE + LCD_WROI_DATA) = dat;
+}
+
+/* ── Hardware init sequence ─────────────────────────────────────────────── */
+
+static void mt6261_lcd_hw_init(void)
+{
+    /*
+     * TODO: Replace this stub with the real init sequence extracted
+     * from dump_preloader.bin.
+     *
+     * To extract:
+     * 1. Search dump.bin for 0x800B0000 references (see file header)
+     * 2. Disassemble surrounding Thumb code with:
+     *    arm-none-eabi-objdump -D -b binary -m arm -M force-thumb \
+     *        --adjust-vma=0x70006000 dump_preloader.bin > pre.dis
+     *    grep -n "800b0000\|800B0000" pre.dis
+     * 3. Transcribe the STR instructions as lcd_write_cmd/lcd_write_dat
+     *    calls below.
+     *
+     * The sequence will look something like:
+     *   lcd_write_cmd(0x01);   // software reset
+     *   msleep(120);
+     *   lcd_write_cmd(0x11);   // sleep out
+     *   msleep(120);
+     *   lcd_write_cmd(0x3A);   // pixel format
+     *   lcd_write_dat(0x55);   // RGB565
+     *   ... etc
+     *
+     * Common panels on MT6261 phones:
+     *   ILI9341  (most common at 240x320)
+     *   ST7789V
+     *   ILI9163C (128x160 — probably not this one at 240x320)
+     *
+     * The panel ID can be read back via CMD 0x04 (RDID).
+     */
+
+    /* Step 1: Assert LCD reset via GPIO */
+    gpio_out(LCD_RESET_GPIO, 0);
+    msleep(10);
+    gpio_out(LCD_RESET_GPIO, 1);
+    msleep(120);
+
+    /* Step 2: Configure MT6261 parallel LCD interface */
+    REG32(MT6261_LCD_BASE + LCD_PARALLEL_CFG) = LCD_PAR_16BIT;
+
+    /* Step 3: Panel-specific init — STUB, fill from dump */
+    /* ILI9341 init as placeholder — replace with real sequence */
+    lcd_write_cmd(0x01);            /* Software reset                       */
+    msleep(150);
+    lcd_write_cmd(0x11);            /* Sleep out                            */
+    msleep(120);
+    lcd_write_cmd(0x3A);            /* Pixel format set                     */
+    lcd_write_dat(0x55);            /* 16bpp RGB565                         */
+    lcd_write_cmd(0x36);            /* Memory access control                */
+    lcd_write_dat(0x48);            /* Row/col order for portrait 240x320   */
+    lcd_write_cmd(0x2A);            /* Column address set                   */
+    lcd_write_dat(0x00);
+    lcd_write_dat(0x00);
+    lcd_write_dat(0x00);
+    lcd_write_dat(0xEF);            /* 239 = width-1                        */
+    lcd_write_cmd(0x2B);            /* Page address set                     */
+    lcd_write_dat(0x00);
+    lcd_write_dat(0x00);
+    lcd_write_dat(0x01);
+    lcd_write_dat(0x3F);            /* 319 = height-1                       */
+    lcd_write_cmd(0x29);            /* Display on                           */
+    msleep(10);
+}
+
+/* ── Framebuffer DMA to panel ───────────────────────────────────────────── */
+
+static void lcd_flush(void)
+{
+    /*
+     * Set up MT6261 LCD DMA layer to blit the framebuffer to the panel.
+     * The MT6261 LCD controller can DMA directly from SRAM.
+     */
+
+    /* Set ROI (region of interest) = full screen */
+    REG32(MT6261_LCD_BASE + LCD_WROI_SIZE) =
+        (LCD_FB_WIDTH) | (LCD_FB_HEIGHT << 16);
+
+    /* Layer 0: source = framebuffer, RGB565, full width */
+    REG32(MT6261_LCD_BASE + LCD_LAYER0_SRC)     = LCD_FB_BASE;
+    REG32(MT6261_LCD_BASE + LCD_LAYER0_PITCHSZ) =
+        LCD_FB_STRIDE | (LCD_FB_WIDTH << 16);
+    REG32(MT6261_LCD_BASE + LCD_LAYER0_WINDOW)  = 0; /* x=0, y=0 */
+    REG32(MT6261_LCD_BASE + LCD_LAYER0_CTRL)    =
+        LCD_LAYER_RGB565 | LCD_LAYER_EN_BIT;
+    REG32(MT6261_LCD_BASE + LCD_LAYER_EN)       = 1; /* enable layer 0 */
+
+    /* Set write-to-panel command (ILI9341: 0x2C = RAMWR) */
+    lcd_write_cmd(0x2C);
+
+    /* Start DMA transfer */
+    REG32(MT6261_LCD_BASE + LCD_WROI_CTRL) = LCD_CTRL_START;
+
+    /* Wait for completion */
+    lcd_wait_ready();
+}
+
+/* ── Public API ─────────────────────────────────────────────────────────── */
+
+void mt6261_lcd_init(void)
+{
+    extern void uart_puts(const char *);
+    uart_puts("LCD: init 240x320 RGB565...\r\n");
+
+    /* Enable LCD clock */
+    REG32(MT6261_PDN_CLR0) = PDN0_LCD;
+
+    /* Enable backlight */
+    gpio_out(LCD_BL_GPIO, 1);
+
+    /* Hardware init */
+    mt6261_lcd_hw_init();
+
+    /* Clear framebuffer to black */
+    lcd_fill(LCD_COLOR_BLACK);
+
+    /* Flush to panel */
+    lcd_flush();
+
+    uart_puts("LCD: ready\r\n");
+}
+
+void lcd_fill(unsigned short color)
+{
+    int i;
+    for (i = 0; i < LCD_FB_WIDTH * LCD_FB_HEIGHT; i++)
+        fb[i] = color;
+    lcd_flush();
+}
+
+void lcd_putpixel(int x, int y, unsigned short color)
+{
+    if (x < 0 || x >= LCD_FB_WIDTH || y < 0 || y >= LCD_FB_HEIGHT)
+        return;
+    fb[y * LCD_FB_WIDTH + x] = color;
+}
+
+unsigned short lcd_getpixel(int x, int y)
+{
+    if (x < 0 || x >= LCD_FB_WIDTH || y < 0 || y >= LCD_FB_HEIGHT)
+        return 0;
+    return fb[y * LCD_FB_WIDTH + x];
+}
+
+void lcd_hline(int x, int y, int w, unsigned short color)
+{
+    int i;
+    for (i = 0; i < w; i++)
+        lcd_putpixel(x + i, y, color);
+}
+
+void lcd_vline(int x, int y, int h, unsigned short color)
+{
+    int i;
+    for (i = 0; i < h; i++)
+        lcd_putpixel(x, y + i, color);
+}
+
+void lcd_rect(int x, int y, int w, int h, unsigned short color)
+{
+    lcd_hline(x,     y,     w, color);
+    lcd_hline(x,     y+h-1, w, color);
+    lcd_vline(x,     y,     h, color);
+    lcd_vline(x+w-1, y,     h, color);
+}
+
+void lcd_fillrect(int x, int y, int w, int h, unsigned short color)
+{
+    int i, j;
+    for (j = y; j < y + h; j++)
+        for (i = x; i < x + w; i++)
+            lcd_putpixel(i, j, color);
+}
diff --git a/arch/arm/mt6261/lcd.h b/arch/arm/mt6261/lcd.h
new file mode 100644
index 0000000..b364e71
