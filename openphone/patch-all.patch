+/* include/arch/arm/asmdefs.h
+ * OpenPhone — ARM assembly helper macros
+ *
+ * Copyright (C) 2026 OpenPhone Project
+ * SPDX-License-Identifier: GPL-2.0-only
+ */
+
+#ifndef ARCH_ARM_ASMDEFS_H
+#define ARCH_ARM_ASMDEFS_H
+
+#ifdef __ASSEMBLER__
+
+/* Standard function prologue/epilogue for ARM AAPCS */
+.macro FUNC_START name
+    .global \name
+    .type   \name, %function
+\name:
+.endm
+
+.macro FUNC_END name
+    .size \name, . - \name
+.endm
+
+#endif /* __ASSEMBLER__ */
+
+#endif /* ARCH_ARM_ASMDEFS_H */
