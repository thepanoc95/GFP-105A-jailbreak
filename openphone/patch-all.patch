+/* include/arch/arm/types.h
+ * OpenPhone — ARM type definitions
+ *
+ * Copyright (C) 2026 OpenPhone Project
+ * SPDX-License-Identifier: GPL-2.0-only
+ */
+
+#ifndef ARCH_ARM_TYPES_H
+#define ARCH_ARM_TYPES_H
+
+typedef unsigned char       u8;
+typedef unsigned short      u16;
+typedef unsigned int        u32;
+typedef unsigned long long  u64;
+
+typedef signed char         s8;
+typedef signed short        s16;
+typedef signed int          s32;
+typedef signed long long    s64;
+
+typedef u32                 ucell;      /* unsigned cell — 32-bit on ARM    */
+typedef s32                 cell;       /* signed cell                      */
+typedef u32                 uaddr;      /* address type                     */
+
+#define BITS_PER_LONG       32
+#define UCELL_MAX           0xFFFFFFFFUL
+
+#endif /* ARCH_ARM_TYPES_H */