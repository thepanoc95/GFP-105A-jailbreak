diff --git a/arch/arm/mt6261/build.xml b/arch/arm/mt6261/build.xml
new file mode 100644
index 0000000..4013080
--- /dev/null
+++ b/arch/arm/mt6261/build.xml
@@ -0,0 +1,37 @@
+<build condition="ARM_MT6261">
+
+ <!-- OpenPhone Forth dictionary for GFP-105A -->
+ <dictionary name="openbios-arm-mt6261" init="openbios">
+  <object source="cpu.fs"  target="forth"/>
+  <object source="init.fs" target="forth"/>
+ </dictionary>
+
+ <!-- MT6261 arch library -->
+ <library name="arm-mt6261" type="static" target="target">
+  <object source="openbios.c"/>
+  <object source="uart.c"/>
+  <object source="msdc.c"/>
+  <object source="usb_cdc.c"/>
+  <object source="devices.c"/>
+  <object source="entry.S"/>
+ </library>
+
+ <!-- Stage 1 flat binary (GFH shim — flashed to NOR) -->
+ <executable name="openphone-stage1.elf" target="target" condition="IMAGE_ELF">
+  <rule>
+	$(call quiet-command,$(LD) --warn-common -N -T $(SRCDIR)/arch/arm/mt6261/ldscript -o $@.nostrip --whole-archive $^,   "  LINK  $(TARGET_DIR)$@")
+	$(call quiet-command,$(NM) $@.nostrip | sort > $(ODIR)/openphone-stage1.syms,                                          "  GEN   $(TARGET_DIR)$@.syms")
+	$(call quiet-command,$(STRIP) $@.nostrip -o $@,                                                                        "  STRIP $(TARGET_DIR)$@")
+	$(call quiet-command,$(OBJCOPY) -O binary $@ $(ODIR)/openphone-stage1.bin,                                             "  BIN   $(TARGET_DIR)openphone-stage1.bin")
+	$(call quiet-command,python3 $(SRCDIR)/arch/arm/mt6261/pack_gfh.py $(ODIR)/openphone-stage1.bin $(GFH_DUMP) $(ODIR)/openphone-stage1-final.bin, "  GFH   $(TARGET_DIR)openphone-stage1-final.bin")</rule>
+  <external-object source="libarm-mt6261.a"/>
+  <external-object source="libbootstrap.a"/>
+  <external-object source="libopenbios.a"/>
+  <external-object source="libpackages.a"/>
+  <external-object source="libdrivers.a"/>
+  <external-object source="libfs.a"/>
+  <external-object source="liblibc.a"/>
+  <external-object source="libgcc.a"/>
+ </executable>
+
+</build>
diff --git a/arch/arm/mt6261/cpu.fs b/arch/arm/mt6261/cpu.fs
new file mode 100644
index 0000000..7beaa32
--- /dev/null
+++ b/arch/arm/mt6261/cpu.fs
@@ -0,0 +1,115 @@
+\ arch/arm/mt6261/cpu.fs
+\ OpenPhone — MT6261 CPU Forth words
+\
+\ Copyright (C) 2026 OpenPhone Project
+\ SPDX-License-Identifier: GPL-2.0-only
+\
+\ Defines low-level Forth words for MT6261 hardware access.
+\ These are available from the OpenPhone 'ok' prompt.
+
+." OpenPhone MT6261 CPU words loading..." cr
+
+\ ── Memory-mapped I/O ───────────────────────────────────────────────────────
+
+\ ( addr -- val )  Read 32-bit register
+: l@  ( addr -- val )  dup  @ ;
+
+\ ( val addr -- )  Write 32-bit register
+: l!  ( val addr -- )  ! ;
+
+\ ( addr -- val )  Read 8-bit register
+: c@r  ( addr -- val )  c@ ;
+
+\ ( val addr -- )  Write 8-bit register
+: c!r  ( val addr -- )  c! ;
+
+\ ── MT6261 peripheral base addresses ────────────────────────────────────────
+
+hex
+
+80030000 constant UART0-BASE
+80050000 constant MSDC-BASE
+80020000 constant GPIO-BASE
+80000000 constant CONFG-BASE
+
+\ ── UART convenience words ──────────────────────────────────────────────────
+
+\ ( -- val )  Read UART0 line status register
+: uart-lsr  ( -- val )  UART0-BASE 14 + l@ ;
+
+\ ( -- flag )  True if TX holding register is empty
+: uart-txrdy  ( -- flag )  uart-lsr 20 and 0<> ;
+
+\ ( char -- )  Send one character via UART0
+: uart-emit  ( char -- )
+    begin uart-txrdy until
+    UART0-BASE l! ;
+
+\ ( -- char )  Receive one character from UART0 (blocking)
+: uart-key  ( -- char )
+    begin uart-lsr 1 and until
+    UART0-BASE l@ ff and ;
+
+\ ── MSDC / SD card words ────────────────────────────────────────────────────
+
+\ ( -- )  Display MSDC config register
+: msdc-status  ( -- )
+    ." MSDC_CFG:    " MSDC-BASE l@ .  cr
+    ." MSDC_INT:    " MSDC-BASE 0c + l@ . cr
+    ." MSDC_SDC_STS:" MSDC-BASE 3c + l@ . cr ;
+
+\ ( lba buf -- )  Read one 512-byte sector from SD card
+\ Calls the C function registered by mt6261_devices_init
+: sd-read-sector  ( lba buf -- result )
+    msdc-read-sector ;
+
+\ ── GPIO words ──────────────────────────────────────────────────────────────
+
+\ ( pin -- val )  Read GPIO pin state
+: gpio@  ( pin -- val )
+    GPIO-BASE swap 4 * + l@ ;
+
+\ ( val pin -- )  Write GPIO pin
+: gpio!  ( val pin -- )
+    GPIO-BASE swap 4 * + l! ;
+
+\ ── System info ─────────────────────────────────────────────────────────────
+
+: .sysinfo  ( -- )
+    ." OpenPhone v0.1" cr
+    ." Board:  Gradiente Neo Flip 105A (GFP-105A)" cr
+    ." SoC:    MediaTek MT6261 @ 104MHz" cr
+    ." SRAM:   256KB @ " 70000000 . cr
+    ." UART:   115200 8N1 @ " UART0-BASE . cr
+    ." MSDC:   SD card @ " MSDC-BASE . cr ;
+
+\ ── Boot words ──────────────────────────────────────────────────────────────
+
+\ ( -- )  Load and boot from SD card sector 1
+: sd-boot  ( -- )
+    ." Loading from SD..." cr
+    1                       \ start sector
+    70010000                \ load address
+    msdc-read-sector drop
+    ." Jumping to loaded image..." cr
+    70010000 execute ;
+
+\ ── USB CDC words ───────────────────────────────────────────────────────────
+
+80060000 constant USB-BASE
+
+\ ( -- flag )  True if USB host has configured device
+: usb-ready?  ( -- flag )  usb_cdc_configured ;
+
+\ ( -- )  Print active console type
+: .console  ( -- )
+    usb-ready? if
+        ." Console: USB CDC ACM (/dev/ttyACM0)" cr
+    else
+        ." Console: UART0 @ 115200 8N1" cr
+    then ;
+
+decimal
+
+." MT6261 words loaded. Type .sysinfo for system info." cr
+." Type sd-boot to boot from SD card." cr
diff --git a/arch/arm/mt6261/devices.c b/arch/arm/mt6261/devices.c
new file mode 100644
index 0000000..6d1dfc1
--- /dev/null
+++ b/arch/arm/mt6261/devices.c
@@ -0,0 +1,107 @@
+/* arch/arm/mt6261/devices.c
+ * OpenPhone — MT6261 device package registration
+ *
+ * Copyright (C) 2026 OpenPhone Project
+ * SPDX-License-Identifier: GPL-2.0-only
+ *
+ * Registers Forth device packages (drivers) into the OpenFirmware
+ * device tree. Called from arch_of_init() after the Forth kernel
+ * is running.
+ */
+
+#include "config.h"
+#include "libopenbios/bindings.h"
+#include "libopenbios/ofmem.h"
+#include "drivers/drivers.h"
+#include "mt6261.h"
+
+/* Forward declarations */
+int mt6261_msdc_init(void);
+int mt6261_msdc_read(void *dst, unsigned int lba, unsigned int count);
+void uart_puts(const char *s);
+void uart_puthex(unsigned int v);
+
+/* ── UART Forth package ─────────────────────────────────────────────────── */
+
+/*
+ * ( -- )  emit  ( char -- )
+ * OpenFirmware UART emit word.
+ */
+static void uart_emit_word(void)
+{
+    int c = POP();
+    extern void uart_putc(int);
+    uart_putc(c);
+}
+
+/*
+ * ( -- char )  key
+ */
+static void uart_key_word(void)
+{
+    extern int uart_getc(void);
+    PUSH(uart_getc());
+}
+
+/*
+ * ( -- flag )  key?
+ */
+static void uart_key_q_word(void)
+{
+    extern int uart_tstc(void);
+    PUSH(uart_tstc() ? -1 : 0);
+}
+
+static void mt6261_uart_register(void)
+{
+    bind_func("mt6261-uart-emit",  uart_emit_word);
+    bind_func("mt6261-uart-key",   uart_key_word);
+    bind_func("mt6261-uart-key?",  uart_key_q_word);
+
+    /* Patch OpenFirmware emit/key to use our UART */
+    feval("['] mt6261-uart-emit to emit");
+    feval("['] mt6261-uart-key  to key");
+    feval("['] mt6261-uart-key? to key?");
+}
+
+/* ── MSDC / SD card Forth package ───────────────────────────────────────── */
+
+/*
+ * ( lba buf -- flag )  msdc-read-sector
+ * Read one 512-byte sector from SD card into buf.
+ * Returns 0 on success, -1 on error.
+ */
+static void msdc_read_sector_word(void)
+{
+    void *buf    = (void *)POP();
+    unsigned int lba = (unsigned int)POP();
+    int result   = mt6261_msdc_read(buf, lba, 1);
+    PUSH(result);
+}
+
+/*
+ * ( -- )  msdc-init
+ */
+static void msdc_init_word(void)
+{
+    int result = mt6261_msdc_init();
+    PUSH(result);
+}
+
+static void mt6261_msdc_register(void)
+{
+    bind_func("msdc-init",        msdc_init_word);
+    bind_func("msdc-read-sector", msdc_read_sector_word);
+}
+
+/* ── Register all MT6261 devices ────────────────────────────────────────── */
+
+void mt6261_devices_init(void)
+{
+    uart_puts("Registering MT6261 device packages...\r\n");
+
+    mt6261_uart_register();
+    mt6261_msdc_register();
+
+    uart_puts("Devices OK\r\n");
+}
diff --git a/arch/arm/mt6261/entry.S b/arch/arm/mt6261/entry.S
new file mode 100644
index 0000000..c2e834b
--- /dev/null
+++ b/arch/arm/mt6261/entry.S
@@ -0,0 +1,120 @@
+/*
+ * arch/arm/mt6261/entry.S
+ * OpenPhone - OpenBIOS port for ARM/MT6261
+ * Target: Gradiente Neo Flip 105A (GFP-105A)
+ *
+ * Copyright (C) 2026 OpenPhone Project
+ * SPDX-License-Identifier: GPL-2.0-only
+ *
+ * Entry point layout in NOR flash:
+ *   0x000  GFH header placeholder (0x60 bytes, patched by pack_gfh.py)
+ *   0x060  ARM exception vector table
+ *   0x080  _start — actual BROM entry
+ *
+ * The BROM loads us to SRAM at 0x70006000 and jumps to entry point
+ * at load_addr + jump_off = 0x70006000 + 0x140 = 0x70006140.
+ * Our linker places _start at that address.
+ */
+
+#include "mt6261.h"
+
+    .syntax unified
+    .arch   armv4t
+    .arm
+
+/* ── GFH header placeholder ─────────────────────────────────────────────────
+ * 0x60 bytes of zeros. pack_gfh.py overwrites this with the real GFH
+ * extracted from the OEM firmware dump before flashing.
+ */
+    .section .gfh, "a"
+    .global _gfh_placeholder
+_gfh_placeholder:
+    .fill 0x60, 1, 0x00
+
+/* ── ARM exception vector table ─────────────────────────────────────────────
+ * Placed at load_addr (0x70006000) after GFH.
+ * The BROM copies us to SRAM so this becomes the live vector table.
+ */
+    .section .vectors, "ax"
+    .global _vectors
+_vectors:
+    ldr     pc, =_start             /* 0x00  Reset            */
+    ldr     pc, =_undef_handler     /* 0x04  Undefined        */
+    ldr     pc, =_swi_handler       /* 0x08  SWI              */
+    ldr     pc, =_prefetch_handler  /* 0x0C  Prefetch abort   */
+    ldr     pc, =_data_handler      /* 0x10  Data abort       */
+    .word   0x00000000              /* 0x14  Reserved         */
+    ldr     pc, =_irq_handler       /* 0x18  IRQ              */
+    ldr     pc, =_fiq_handler       /* 0x1C  FIQ              */
+
+/* ── Exception handlers ─────────────────────────────────────────────────── */
+_undef_handler:
+    ldr     r0, =str_undef
+    bl      uart_puts
+    b       .
+
+_swi_handler:
+_prefetch_handler:
+_data_handler:
+_irq_handler:
+_fiq_handler:
+    b       .
+
+/* ── _start — Stage 1 entry point ───────────────────────────────────────────
+ * Placed at 0x70006140 (load_addr + jump_off from GFH).
+ * BROM jumps here after loading us into SRAM.
+ */
+    .section .text.start, "ax"
+    .global _start
+_start:
+    /* Disable IRQ + FIQ, enter SVC mode */
+    msr     cpsr_c, #0xD3
+
+    /* Stack at top of our SRAM region */
+    ldr     sp, =OPENPHONE_STACK_TOP
+
+    /* Clear BSS */
+    ldr     r0, =__bss_start
+    ldr     r1, =__bss_end
+    mov     r2, #0
+.Lbss_clear:
+    cmp     r0, r1
+    strlo   r2, [r0], #4
+    blo     .Lbss_clear
+
+    /* Initialise UART0 for console I/O */
+    bl      mt6261_uart_init
+
+    /* Print OpenPhone banner */
+    ldr     r0, =str_banner
+    bl      uart_puts
+
+    /* Initialise SD card controller */
+    bl      mt6261_msdc_init
+
+    /* Load OpenBIOS image from SD into SRAM */
+    ldr     r0, =OPENBIOS_LOAD_ADDR
+    mov     r1, #OPENBIOS_SD_SECTOR
+    mov     r2, #OPENBIOS_SD_SECTORS
+    bl      mt6261_msdc_read
+
+    /* Jump to OpenBIOS */
+    ldr     r0, =str_jumping
+    bl      uart_puts
+    ldr     r3, =OPENBIOS_LOAD_ADDR
+    bx      r3
+
+    /* Should never reach here */
+    b       .
+
+/* ── String constants ───────────────────────────────────────────────────── */
+    .section .rodata
+str_banner:
+    .asciz  "\r\n\r\nOpenPhone/" OPENPHONE_VERSION "\r\n"
+    .asciz  "GFP-105A / MT6261 / WD031 SS V00\r\n\r\n"
+str_jumping:
+    .asciz  "Jumping to OpenBIOS...\r\n"
+str_undef:
+    .asciz  "\r\n*** Undefined instruction ***\r\n"
+
+    .end
